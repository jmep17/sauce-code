{
  "name": "sauce-code",
  "version": "0.1.0",
  "description": "Point at any Vite/Next/Astro app and run it against automatically generated mocks.",
  "type": "module",
  "bin": {
    "sauce-code": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "verify:generate": "tsx scripts/verify-generate.ts",
    "verify:fixture": "tsx scripts/verify-fixture.ts",
    "postinstall": "playwright install chromium || true"
  },
  "keywords": [
    "mocks",
    "msw",
    "playwright",
    "vite",
    "nextjs",
    "astro",
    "auth0",
    "testing"
  ],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "dotenv": "^16.4.5",
    "execa": "^9.5.1",
    "fast-glob": "^3.3.2",
    "get-port": "^7.1.0",
    "jose": "^5.9.6",
    "picocolors": "^1.1.1",
    "playwright": "^1.49.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "msw": "^2.7.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
